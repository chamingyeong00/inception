DOMAIN_NAME=micha.42.fr

# Database Settings
DB_NAME=wordpress_db
DB_USER=wp_user
# DB_PASSWORD 및 DB_ROOT_PASSWORD는 secrets 폴더의 텍스트 파일로 관리하는 것을 권장하지만,
# 기본적인 작동을 위해 .env에 넣는 방식도 과제에서 허용됩니다.
DB_PASSWORD=your_secure_password
DB_ROOT_PASSWORD=your_root_password

# WordPress Settings
WP_ADMIN_USER=wp_superuser # admin, administrator 포함 금지
WP_ADMIN_PASSWORD=your_admin_password
WP_ADMIN_EMAIL=admin@student.42.fr
WP_USER=ordinary_user
WP_USER_PASSWORD=ordinary_password
WP_USER_EMAIL=user@student.42.fr